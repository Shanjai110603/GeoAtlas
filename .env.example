PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Database (PostgreSQL + PostGIS)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=geoatlas
POSTGRES_PASSWORD=geoatlas_secret
POSTGRES_DB=geoatlas

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Search Engine (Meilisearch)
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=geoatlas_meili_master_key

# Routing Engine (OSRM)
OSRM_URL=http://localhost:5000

# Object Storage (MinIO / S3)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=geoatlas_minio
STORAGE_SECRET_KEY=geoatlas_minio_secret
STORAGE_BUCKET=geoatlas-media

# Nominatim (Geocoding Proxy)
NOMINATIM_URL=https://nominatim.openstreetmap.org

# Auth & Secrets
JWT_SECRET=super_secret_jwt_key_geoatlas_phase1_change_in_production
